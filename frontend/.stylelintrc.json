{
    "extends": [
        "stylelint-config-standard-scss"
    ],
    "rules": {
        "scss/at-rule-no-unknown": [
            true,
            {
                "ignoreAtRules": [
                    "theme",
                    "import",
                    "apply",
                    "layer",
                    "screen",
                    "variants",
                    "responsive",
                    "tailwind"
                ]
            }
        ]
    }
}